{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "appsettings": {
    "redisconnection": "localhost:6379"
  },
  "dbSettings": {
    "oracleconnection": "User Id=myUsername;Password=myPassword;Data Source=myOracleDB",
    "mongodbconnection": "mongodb://localhost:27017"
  },
  "ConnectionStrings": {
    "Default": "User Id=myUsername;Password=myPassword;Data Source=myOracleDB"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092"
  },
  "HealthChecks": {
    "FilePath": "C:\\temp\\healthcheck",
    "TimeoutSeconds": 3
  }
}
